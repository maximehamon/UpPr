# Apify API key from https://console.apify.com/account/integrations
APIFY_API_KEY=apify_...
# OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Slack incoming webhook URL from https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Base URL of this app (for OpenRouter ranking headers)
APP_BASE_URL=http://localhost:8000
# Secret key for session security
SECRET_KEY=change-me-in-production
